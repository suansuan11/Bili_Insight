# B站登录凭证配置示例
# 复制此文件为 .env 并填入你的真实凭证

# ===== 数据库配置 =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=bili_insight_db

# ===== B站登录凭证（可选）=====
# 用于获取需要登录的数据（评论、弹幕等）
# 获取方法：
# 1. 浏览器访问 https://www.bilibili.com 并登录
# 2. 按F12打开开发者工具 → Application → Cookies → https://www.bilibili.com
# 3. 找到以下字段并复制值

# SESSDATA（必需）
BILI_SESSDATA=

# bili_jct（可选，用于需要csrf验证的操作）
BILI_JCT=

# buvid3（可选）
BILI_BUVID3=

# ===== 服务配置 =====
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8001
