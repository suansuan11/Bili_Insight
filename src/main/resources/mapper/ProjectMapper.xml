<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ecut.bili_insight.mapper.ProjectMapper">
    <resultMap id="ProjectResultMap" type="com.ecut.bili_insight.entity.Project">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="keywords" column="keywords"/>
        <result property="targetBvids" column="target_bvids"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findByUserId" resultMap="ProjectResultMap">
        SELECT * FROM project
        <where>
            <if test="userId != null">
                user_id = #{userId}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <select id="findAll" resultMap="ProjectResultMap">
        SELECT * FROM project ORDER BY created_at DESC
    </select>

    <select id="findById" resultMap="ProjectResultMap">
        SELECT * FROM project WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO project (user_id, name, description, keywords, target_bvids, created_at, updated_at)
        VALUES (#{userId}, #{name}, #{description}, #{keywords}, #{targetBvids}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE project
        SET name = #{name},
            description = #{description},
            keywords = #{keywords},
            target_bvids = #{targetBvids},
            updated_at = NOW()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM project WHERE id = #{id}
    </delete>

    <select id="countByUserId" resultType="int">
        SELECT COUNT(*) FROM project WHERE user_id = #{userId}
    </select>
</mapper>
